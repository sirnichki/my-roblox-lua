-- ИСПРАВЛЕННЫЙ Server Hop
CreateButton(tabMisc, "Server Hop", function()
    pcall(function()
        local api = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100"
        local success, result = pcall(function()
            return game:HttpGet(api)
        end)
        
        if success then
            local decoded = game:GetService("HttpService"):JSONDecode(result)
            if decoded and decoded.data then
                for _, server in pairs(decoded.data) do
                    if server.id ~= game.JobId and tonumber(server.playing) and tonumber(server.maxPlayers) then
                        if server.playing < server.maxPlayers then
                            game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, server.id, Player)
                            break
                        end
                    end
                end
            end
        else
            -- Fallback: просто реджойн
            game:GetService("TeleportService"):Teleport(game.PlaceId, Player)
        end
    end)
end, "Сменить сервер (свободные слоты)")

