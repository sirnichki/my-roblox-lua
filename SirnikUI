-- Табы
local Tabs = {}
local ActiveTab = nil
local TabButtonsList = {}

function CreateTab(name)
    local tabFrame = Instance.new("Frame", G2L["TabContent"])
    tabFrame.Size = UDim2.new(1, 0, 0, 400)
    tabFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    tabFrame.BorderSizePixel = 0
    tabFrame.Visible = false

    local btn = Instance.new("TextButton", G2L["TabButtons"])
    btn.Size = UDim2.new(0, 100, 1, 0)
    btn.Position = UDim2.new(0, (#TabButtonsList) * 100, 0, 0)
    btn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.TextScaled = true
    btn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false

    btn.MouseButton1Click:Connect(function()
        if ActiveTab then
            Tabs[ActiveTab].Visible = false
            TabButtonsList[ActiveTab].BackgroundColor3 = Color3.fromRGB(55, 55, 55)
        end
        tabFrame.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        ActiveTab = name
    end)

    Tabs[name] = tabFrame
    TabButtonsList[name] = btn

    if #TabButtonsList == 1 then
        tabFrame.Visible = true
        btn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        ActiveTab = name
    end

    return tabFrame
end

-- Кнопка
function CreateButton(parent, text, callback, desc)
    local yOffset = 0
    for _, v in pairs(parent:GetChildren()) do
        if v:IsA("TextButton") or v:IsA("TextLabel") or v:IsA("TextBox") then
            yOffset = yOffset + 55
        end
    end

    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 260, 0, 40)
    btn.Position = UDim2.new(0, 10, 0, yOffset)
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", btn).Thickness = 1.5

    btn.MouseButton1Click:Connect(callback)

    if desc then
        local lbl = Instance.new("TextLabel", parent)
        lbl.Size = UDim2.new(0, 260, 0, 15)
        lbl.Position = UDim2.new(0, 15, 0, yOffset + 40)
        lbl.BackgroundTransparency = 1
        lbl.Text = desc
        lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
        lbl.TextScaled = true
        lbl.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Light, Enum.FontStyle.Normal)
        lbl.BorderSizePixel = 0
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextSize = 14
    end

    return btn
end

-- TextBox + Apply
function CreateTextBox(parent, label, default, onApply, desc)
    local yOffset = 0
    for _, v in pairs(parent:GetChildren()) do
        if v:IsA("TextButton") or v:IsA("TextLabel") or v:IsA("TextBox") then
            yOffset = yOffset + 55
        end
    end

    local lbl = Instance.new("TextLabel", parent)
    lbl.Size = UDim2.new(0, 80, 0, 35)
    lbl.Position = UDim2.new(0, 10, 0, yOffset + 5)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    lbl.TextScaled = true
    lbl.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
    lbl.BorderSizePixel = 0
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local box = Instance.new("TextBox", parent)
    box.Size = UDim2.new(0, 100, 0, 35)
    box.Position = UDim2.new(0, 95, 0, yOffset + 5)
    box.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
    box.Text = tostring(default)
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.TextScaled = true
    box.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = false
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 5)

    local apply = Instance.new("TextButton", parent)
    apply.Size = UDim2.new(0, 70, 0, 35)
    apply.Position = UDim2.new(0, 200, 0, yOffset + 5)
    apply.BackgroundColor3 = Color3.fromRGB(0, 120, 60)
    apply.Text = "Apply"
    apply.TextColor3 = Color3.fromRGB(255, 255, 255)
    apply.TextScaled = true
    apply.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
    apply.BorderSizePixel = 0
    Instance.new("UICorner", apply).CornerRadius = UDim.new(0, 5)
    Instance.new("UIStroke", apply).Thickness = 1.5

    apply.MouseButton1Click:Connect(function()
        local val = tonumber(box.Text)
        if val then
            onApply(val)
        end
    end)

    if desc then
        local d = Instance.new("TextLabel", parent)
        d.Size = UDim2.new(0, 260, 0, 15)
        d.Position = UDim2.new(0, 15, 0, yOffset + 40)
        d.BackgroundTransparency = 1
        d.Text = desc
        d.TextColor3 = Color3.fromRGB(150, 150, 150)
        d.TextScaled = true
        d.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Light, Enum.FontStyle.Normal)
        d.BorderSizePixel = 0
        d.TextXAlignment = Enum.TextXAlignment.Left
    end

    return box, apply
end

-- Toggle
function CreateToggle(parent, text, getState, setState, desc)
    local btn = CreateButton(parent, text, function()
        setState(not getState())
        if getState() then
            btn.BackgroundColor3 = Color3.fromRGB(0, 150, 50)
            btn.Text = text .. " [ON]"
        else
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            btn.Text = text .. " [OFF]"
        end
    end, desc)

    if getState() then
        btn.BackgroundColor3 = Color3.fromRGB(0, 150, 50)
        btn.Text = text .. " [ON]"
    else
        btn.Text = text .. " [OFF]"
    end

    return btn
end

